{
  "name": "@line-crm/shared",
  "version": "0.2.0",
  "description": "Shared types and constants for LINE CRM",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./internal-form-logic": {
      "types": "./dist/internal-form-logic.d.ts",
      "import": "./dist/internal-form-logic.js",
      "default": "./src/internal-form-logic.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "line",
    "crm",
    "types"
  ]
}
